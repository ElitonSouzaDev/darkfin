# ─── Banco de dados (Neon PostgreSQL) ────────────────────────────────────────
# Copie as duas URLs do painel do Neon (Connection Details → Connection string)

# URL com pooling — usada pelo app em produção
DATABASE_URL="postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require"

# URL direta — usada pelo Prisma para push/migrations
DIRECT_URL="postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require"

# ─── NextAuth ─────────────────────────────────────────────────────────────────
# Gere um secret forte: openssl rand -base64 32
NEXTAUTH_SECRET="cole-aqui-um-secret-forte-gerado"

# URL do seu app na Vercel (sem barra no final)
NEXTAUTH_URL="https://seu-app.vercel.app"
